# Just Count — Environment Variables
# Copy file ini jadi `.env` untuk development local.
# Untuk production (Railway), set di Railway dashboard → Variables.

# === WAJIB di production ===
# Random string min 32 char. Generate: openssl rand -hex 32
SESSION_SECRET=ganti-dengan-random-32char-string-yang-aman

# Bootstrap super admin pertama (kalau DB kosong, sistem auto-seed user ini)
ADMIN_EMAIL=admin@justcount.id
ADMIN_PASSWORD=admin123

# Production flag — wajib di Railway
NODE_ENV=production

# === OPSIONAL ===
# Port (Railway auto-set; lokal default 3000)
PORT=3000

# Path persistent data (Railway: /data setelah mount volume; lokal: kosongkan)
DATA_DIR=/data

# SKA Checker API endpoint (default ke tool kamu sendiri)
SKA_API_URL=https://cek-sertifikat-keahlian.up.railway.app
SKA_CACHE_TTL_DAYS=30
